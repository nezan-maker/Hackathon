NODE_ENV=production
PORT=5500

# Required
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>
AUTH_SECRET=<generate-a-strong-64-char-secret>
REFRESH_SECRET=<generate-a-second-strong-64-char-secret>

# Recommended for key rotation in production
AUTH_SECRETS=<newest-secret>,<previous-secret>
REFRESH_SECRETS=<newest-secret>,<previous-secret>

# Render URLs
FRONTEND_APP_URL=https://your-frontend.onrender.com
BACKEND_APP_URL=https://your-backend.onrender.com
CORS_ORIGINS=https://your-frontend.onrender.com
TRUST_PROXY=1

# Optional email settings
USER_NAME=
USER_PASS=

# Optional MQTT settings
ENABLE_MQTT=false
MQTT_BROKER_URL=
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=8883
MQTT_NODE_USERNAME=
MQTT_NODE_PASSWORD=
MQTT_DEVICE_USERNAME=
MQTT_DEVICE_PASSWORD=

# Optional app settings
ADMIN_EMAILS=
GEO_IP_BASE_URL=https://ipwho.is
GEO_IP_TIMEOUT_MS=2500
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
