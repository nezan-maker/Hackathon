NODE_ENV=development
PORT=5500
MONGO_URI=mongodb://localhost:27017/flowbot
AUTH_SECRET=replace-with-strong-random-secret
REFRESH_SECRET=replace-with-another-strong-random-secret
# Rotation-ready comma-separated secrets (first is current signing secret)
AUTH_SECRETS=replace-with-strong-random-secret,replace-with-previous-secret
REFRESH_SECRETS=replace-with-another-strong-random-secret,replace-with-previous-refresh-secret

# Comma-separated frontend origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5500
TRUST_PROXY=loopback

# SMTP credentials for email verification and password reset
USER_NAME=
USER_PASS=

# Frontend app URL used in transactional links sent via email
FRONTEND_APP_URL=http://localhost:5173

# IP geolocation provider settings
GEO_IP_BASE_URL=https://ipwho.is
GEO_IP_TIMEOUT_MS=2500

# Stripe payment settings (optional for real card processing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Comma-separated emails that should have admin access
ADMIN_EMAILS=admin@example.com

# MQTT integration (optional)
ENABLE_MQTT=false
# Optional full URL, e.g. mqtts://xxxx.s1.eu.hivemq.cloud:8883
MQTT_BROKER_URL=
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=8883
MQTT_NODE_USERNAME=
MQTT_NODE_PASSWORD=
MQTT_DEVICE_USERNAME=
MQTT_DEVICE_PASSWORD=
